{
  "name": "aqua-fantasia",
  "private": true,
  "version": "2.0.17",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build --base=./",
    "preview": "vite preview --host 0.0.0.0",
    "validate": "node tools/clean-old-patch-docs.mjs && node tools/validate-clean.mjs && node tools/check-v2017-direction-ui-polish.mjs",
    "runtime:check": "node tools/check-v2014-background-dock-scroll-polish.mjs --runtime",
    "audit": "node tools/validate-clean.mjs && node tools/check-v2014-background-dock-scroll-polish.mjs --audit",
    "typecheck": "tsc --noEmit",
    "ci:install": "npm ci --ignore-scripts --no-audit --progress=false --registry=https://registry.npmjs.org/ --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "howler": "^2.2.4",
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "typescript": "^5.6.0",
    "vite": "^8.0.16"
  },
  "overrides": {
    "@protobufjs/aspromise": "1.1.2",
    "@protobufjs/base64": "1.1.2",
    "@protobufjs/path": "1.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
