{
  "name": "aqua-fantasia-engine",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "validate": "node tools/validate-static.mjs",
    "audit": "node tools/audit-bundle.mjs",
    "audit:bundle": "node tools/audit-bundle.mjs",
    "atlas:check": "node tools/generate-webp-atlas.mjs",
    "renderer:check": "node tools/check-v47-renderer.mjs && node tools/check-v49-runtime.mjs && node tools/check-v50-runtime.mjs",
    "runtime:check": "node tools/check-v48-runtime.mjs && node tools/check-v50-runtime.mjs",
    "clean:report": "node tools/clean-bundle-report.mjs",
    "runtime49:check": "node tools/check-v49-runtime.mjs",
    "runtime50:check": "node tools/check-v50-runtime.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "firebase": "latest",
    "howler": "latest",
    "pixi.js": "^8.11.0",
    "vite": "latest"
  },
  "devDependencies": {
    "typescript": "latest"
  },
  "description": "Aqua Fantasia v5.0 - performance focus, runtime UI diet and mobile fishing canvas optimization."
}
